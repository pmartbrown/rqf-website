      <div class="fld"><label>Seller carry</label><div class="inwrap"><span>$</span><input id="s_sc" value="80,000" oninput="fmt(this);stack()"></div></div>
      <div class="fld"><label>Primary lender amount</label><div class="inwrap"><span>$</span><input id="s_pl" value="360,000" oninput="fmt(this);stack()"></div></div>
      <div class="fld"><label>Est. closing costs</label><div class="inwrap"><span>$</span><input id="s_cc" value="12,000" oninput="fmt(this);stack()"></div></div>
      <div class="fld"><label>Est. funding &amp; transaction fees <span class="hint">confirmed in quote</span></label><div class="inwrap"><span>$</span><input id="s_ff" value="8,000" oninput="fmt(this);stack()"></div></div>
      <div class="result bring" id="s_res"><div class="rl" id="s_rl">Estimated cash to close</div><div class="rv" id="s_rv">$0</div></div>
      <button class="btn" onclick="openModal('morby')">Submit this deal →</button>
    </div>
    <div id="pane_echo" style="display:none">
      <div class="purpose">Buy like cash — your end loan repays us at the same-day second closing.</div>
      <div class="fld"><label>Purchase price (cash buy)</label><div class="inwrap"><span>$</span><input id="e_pp" value="300,000" oninput="fmt(this);echo()"></div></div>
      <div class="fld"><label>End loan amount (your refi)</label><div class="inwrap"><span>$</span><input id="e_ln" value="255,000" oninput="fmt(this);echo()"></div></div>
      <div class="fld"><label>Est. closing costs (both closings)</label><div class="inwrap"><span>$</span><input id="e_cc" value="10,000" oninput="fmt(this);echo()"></div></div>
      <div class="fld"><label>Est. funding &amp; transaction fees <span class="hint">confirmed in quote</span></label><div class="inwrap"><span>$</span><input id="e_ff" value="6,000" oninput="fmt(this);echo()"></div></div>
      <div class="result bring" id="e_res"><div class="rl" id="e_rl">Estimated cash to close</div><div class="rv" id="e_rv">$0</div></div>
      <button class="btn" onclick="openModal('echo')">Submit this deal →</button>
    </div>
    <div class="note">Estimates only — exact figures arrive with your written terms in 8 business hours.</div>
  </div>
</div></header>

