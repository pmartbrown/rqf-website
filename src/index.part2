<script>
/* ---------- calculators ---------- */
function num(id){var el=document.getElementById(id);return el?(+(el.value.replace(/[^0-9]/g,''))||0):0}
function fmt(el){const v=el.value.replace(/[^0-9]/g,'');el.value=v?(+v).toLocaleString():''}
function money(n){return '$'+Math.abs(Math.round(n)).toLocaleString()}
function stack(){const pp=num('s_pp'),sc=num('s_sc'),pl=num('s_pl'),cc=num('s_cc'),ff=num('s_ff');const cash=pp+cc+ff-sc-pl;
  const res=document.getElementById('s_res');document.getElementById('s_rv').textContent=money(cash);
  if(cash<=0){res.className='result back';document.getElementById('s_rl').textContent='Estimated cash BACK to you at closing'}
  else{res.className='result bring';document.getElementById('s_rl').textContent='Estimated cash to close'}}
function echo(){const pp=num('e_pp'),ln=num('e_ln'),cc=num('e_cc'),ff=num('e_ff');const cash=pp+cc+ff-ln;
  const res=document.getElementById('e_res');document.getElementById('e_rv').textContent=money(cash);
  if(cash<=0){res.className='result back';document.getElementById('e_rl').textContent='Estimated cash BACK to you at closing'}
  else{res.className='result bring';document.getElementById('e_rl').textContent='Estimated cash to close'}}
function ctab(which,btn){document.querySelectorAll('.ctabs button').forEach(b=>b.classList.remove('on'));btn.classList.add('on');
  document.getElementById('pane_morby').style.display=which==='morby'?'block':'none';
  document.getElementById('pane_echo').style.display=which==='echo'?'block':'none'}
if(document.getElementById('s_res'))stack();if(document.getElementById('e_res'))echo();
/* ---------- modal ---------- */
const CONSENT_HTML='<div class="consent"><label style="display:flex;gap:10px;align-items:flex-start;font-size:13px;color:#54524b;cursor:pointer"><input type="checkbox" required style="margin-top:3px;accent-color:var(--orange)"><span>I agree to the terms and conditions above.</span></label><p style="font-size:11.5px;color:#9a978d;margin-top:10px;line-height:1.55">Real Quick Funds, LLC is committed to protecting and respecting your privacy, and we will only use your personal information to administer your account and to provide the products and services you requested from us. From time to time, we would like to contact you about our products and services, as well as other content that may be of interest to you. You can unsubscribe from these communications at any time. For more information on how to unsubscribe, our privacy practices, and how we are committed to protecting and respecting your privacy, please review our <a href="/privacy/" style="color:var(--orange-d);text-decoration:underline">Privacy Policy</a>. By clicking submit below, you consent to allow Real Quick Funds, LLC to store and process the personal information submitted above to provide you the content requested.</p></div>';
function F(label,type,ph,extra){return {l:label,t:type||'text',p:ph||'',x:extra||''}}
function FS(label,id,options){return {l:label,t:'select',id:id,o:options}}
function DEP(field,depId,depVal){field.dep=depId+'='+depVal;return field}
const BORROWER=[F('Borrower first name'),F('Borrower last name'),F('Borrower email address','email','name@email.com'),F('Borrower phone number','tel','(555) 555-5555')];
const FORMS={
 emd:{title:'EMD Funding Request',sections:[
  {h:'Borrower information',f:BORROWER},
  {h:'Deal information',f:[F('Requested amount','money','25,000'),F('When are the funds required?','date'),F('Subject property address','address','Start typing the address…'),F('End of inspection date','date'),F('Close of escrow date','date')]},
  {h:'Documents',f:[F('Purchase and sale agreement','file'),F('Other relevant documents','file')],note:'Have more documents? You can send additional files after submitting.'},
